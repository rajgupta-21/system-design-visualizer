generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  name String

  email String @unique

  password String

  isVerified Boolean @default(false)

  designs Design[]

  createdAt DateTime @default(now())
}

model Design {
  id String @id @default(uuid())

  title String

  description String?

  previewImage String?

  ownerId String

  image  String?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  nodes Node[]

  edges Edge[]

  createdAt DateTime @default(now())
}

model Node {
  id String @id @default(uuid())

  // reactflow id
  flowId String

  type String

  position Json

  data Json

  designId String

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)
}

model Edge {
  id String @id @default(uuid())

  // reactflow edge id
  flowId String

  source String

  target String

  type String?

  animated Boolean @default(false)

  designId String

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)
}
