generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  isVerified Boolean  @default(false)
  designs    Design[]
  createdAt  DateTime @default(now())
}

model Design {
  id        String   @id @default(uuid())
  title     String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  nodes     Node[]
  edges     Edge[]
  createdAt DateTime @default(now())
}

model Node {
  id       String @id
  type     String
  position Json
  data     Json
  designId String
  design   Design @relation(fields: [designId], references: [id])
}

model Edge {
  id       String  @id
  source   String
  target   String
  type     String?
  animated Boolean @default(false)
  designId String
  design   Design  @relation(fields: [designId], references: [id])
}